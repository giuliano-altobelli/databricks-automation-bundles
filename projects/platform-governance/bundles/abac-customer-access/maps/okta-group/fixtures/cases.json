[
  {
    "name": "allows_empty_array",
    "principal": "missing@example.com",
    "okta_group_names": [],
    "expected": true
  },
  {
    "name": "fails_closed_when_array_is_null",
    "principal": "foobar@example.com",
    "okta_group_names": null,
    "expected": false
  },
  {
    "name": "allows_single_read_group",
    "principal": "foobar@example.com",
    "okta_group_names": ["foo"],
    "expected": true
  },
  {
    "name": "allows_single_admin_view_group",
    "principal": "foobar@example.com",
    "okta_group_names": ["bar"],
    "expected": true
  },
  {
    "name": "allows_multiple_groups_when_all_are_granted",
    "principal": "foobar@example.com",
    "okta_group_names": ["foo", "bar"],
    "expected": true
  },
  {
    "name": "denies_multiple_groups_when_one_is_missing",
    "principal": "foobar@example.com",
    "okta_group_names": ["foo", "baz"],
    "expected": false
  },
  {
    "name": "denies_when_no_groups_match",
    "principal": "foobar@example.com",
    "okta_group_names": ["baz"],
    "expected": false
  },
  {
    "name": "denies_when_only_wrong_principal_matches",
    "principal": "wrong-principal@example.com",
    "okta_group_names": ["restricted"],
    "expected": false
  },
  {
    "name": "denies_inactive_group",
    "principal": "inactive@example.com",
    "okta_group_names": ["inactive"],
    "expected": false
  },
  {
    "name": "denies_future_group",
    "principal": "future@example.com",
    "okta_group_names": ["future"],
    "expected": false
  },
  {
    "name": "denies_expired_group",
    "principal": "expired@example.com",
    "okta_group_names": ["expired"],
    "expected": false
  },
  {
    "name": "allows_group_at_exact_valid_from",
    "principal": "boundary@example.com",
    "okta_group_names": ["starts-now"],
    "expected": true
  },
  {
    "name": "denies_group_at_exact_expiry",
    "principal": "boundary@example.com",
    "okta_group_names": ["expires-now"],
    "expected": false
  },
  {
    "name": "denies_unknown_access_level",
    "principal": "unknown-level@example.com",
    "okta_group_names": ["unknown-level"],
    "expected": false
